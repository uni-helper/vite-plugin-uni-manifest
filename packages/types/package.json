{
  "name": "@uni-helper/uni-manifest-types",
  "type": "module",
  "version": "0.3.0",
  "description": "TypeScript types for uni-app manifest.json configuration",
  "author": {
    "email": "wurui.dev@gmail.com",
    "name": "ModyQyW",
    "url": "https://github.com/ModyQyW"
  },
  "license": "MIT",
  "homepage": "https://github.com/uni-helper/vite-plugin-uni-manifest#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uni-helper/vite-plugin-uni-manifest.git"
  },
  "bugs": "https://github.com/uni-helper/vite-plugin-uni-manifest/issues",
  "keywords": [
    "uni-helper",
    "uni-app",
    "uniapp",
    "manifest",
    "types",
    "typescript"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
